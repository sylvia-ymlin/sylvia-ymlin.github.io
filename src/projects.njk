---
layout: base.njk
title: Projects
permalink: /projects/
---
<div class="container">
  <div class="page-header reveal">
    <p class="page-title">Open Source</p>
    <p class="page-count">{{ github | length }}</p>
    <p class="page-subtitle">Things I've built & explored</p>
  </div>

  <hr class="section-divider" />

  <div class="projects-grid reveal">
    {% for repo in github %}
    <a href="{% if repo.readme %}/projects/{{ repo.slug }}/{% else %}{{ repo.url }}{% endif %}"
       {% if not repo.readme %}target="_blank" rel="noopener"{% endif %}
       class="project-card">

      <div class="project-cover{% if not repo.coverImage %} project-cover--lang{% endif %}"
           {% if not repo.coverImage %}data-lang="{{ repo.language }}"{% endif %}>
        {% if repo.coverImage %}
        <img src="{{ repo.coverImage }}" alt="{{ repo.name }}" loading="lazy">
        {% else %}
        <span class="project-cover-lang-label">{{ repo.language or "Code" }}</span>
        {% endif %}
      </div>

      <div class="project-name">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        {{ repo.name }}
        {% if repo.readme %}<span class="project-has-post">↗</span>{% endif %}
      </div>
      {% if repo.description %}
      <p class="project-desc">{{ repo.description }}</p>
      {% endif %}
      <div class="project-tags">
        {% if repo.language %}
        <span class="project-tag">{{ repo.language }}</span>
        {% endif %}
        {% if repo.stars > 0 %}
        <span class="project-tag">★ {{ repo.stars }}</span>
        {% endif %}
      </div>
    </a>
    {% else %}
    <p style="color: var(--text-tertiary);">No projects found.</p>
    {% endfor %}
  </div>

  <p class="reveal" style="text-align: right; font-size: 0.78rem; color: var(--text-tertiary); margin-top: 0.5rem; padding-bottom: 0.5rem;">
    <a href="https://github.com/sylvia-ymlin" target="_blank" rel="noopener" style="color: inherit;">→ View all on GitHub</a>
  </p>

  <div style="height: 3rem;"></div>
</div>

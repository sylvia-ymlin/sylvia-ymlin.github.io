<!DOCTYPE html>
<html lang="{{ lang or 'en' }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} · {{ site.shortName }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.tagline }}" />
  <meta name="author" content="{{ site.author }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title or site.name }}" />
  <meta property="og:description" content="{{ description or site.tagline }}" />
  <meta property="og:image" content="{{ site.avatar }}" />
  <meta property="og:type" content="website" />

  <!-- Favicon -->
  <link rel="icon" href="{{ site.avatar }}" type="image/png" />

  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Navigation -->
<nav class="nav">
  <div class="nav-logo">
    <a href="/">
      <img src="{{ site.avatar }}" alt="{{ site.shortName }}" class="nav-avatar" />
      <span class="nav-site-name">{{ site.shortName }}</span>
    </a>
  </div>

  <ul class="nav-links">
    {% for item in site.nav %}
    <li><a href="{{ item.url }}">{{ item.label }}</a></li>
    {% endfor %}
  </ul>

  <div class="nav-right">
    <a href="{{ site.github }}" target="_blank" rel="noopener" class="nav-icon" title="GitHub">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
      </svg>
    </a>
  </div>
</nav>

<!-- Main content -->
<main>
  {{ content | safe }}
</main>

<!-- Footer -->
<footer>
  <div class="container">
    <p class="footer-greeting">Spring greetings</p>
    <p class="footer-sub">Welcome to write</p>
    <div class="footer-links">
      {% for item in site.nav %}
      <a href="{{ item.url }}">{{ item.label }}</a>
      {% endfor %}
    </div>
    <p class="footer-copy">© 2026 {{ site.author }} · Built with Eleventy · Hosted on GitHub Pages</p>
  </div>
</footer>

<script src="/assets/js/main.js"></script>
</body>
</html>
